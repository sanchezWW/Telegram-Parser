API_ID=12345678
API_HASH=your_api_hash_here

DEBUG=true

# SQL Server — укажите имя сервера как в SSMS (Connect → Server name)
MSSQL_SERVER=localhost\SQLEXPRESS
MSSQL_DATABASE=TelegramParser
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
MSSQL_TRUSTED_CONNECTION=True

# SQL Authentication (если не Windows Auth):
# MSSQL_TRUSTED_CONNECTION=False
# MSSQL_USERNAME=sa
# MSSQL_PASSWORD=YourStrongPassword
